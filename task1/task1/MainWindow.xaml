<Window x:Class="task1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Работник" Height="350" Width="450">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="Фамилия:" Width="120" Height="30"/>
        <TextBox x:Name="familiaBox" Grid.Row="0" Grid.Column="1" Width="180" Height="25"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Оклад:" Width="120" Height="30"/>
        <TextBox x:Name="okladBox" Grid.Row="1" Grid.Column="1" Width="180" Height="25"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Дата рождения:" Width="120" Height="30"/>
        <DatePicker x:Name="drPicker" Grid.Row="2" Grid.Column="1" Width="180" Height="25"/>

        <Button x:Name="vozrastBtn" Grid.Row="3" Grid.Column="0" Content="Возраст" Click="vozrastBtn_Click" Width="150" Height="30"/>
        <Button x:Name="do50Btn" Grid.Row="3" Grid.Column="1" Content="Дней до 50 лет" Click="do50Btn_Click" Width="150" Height="30"/>

        <TextBox x:Name="resultBox" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Width="350" Height="40" IsReadOnly="True"/>
    </Grid>
</Window>
